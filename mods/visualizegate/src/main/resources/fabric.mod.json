{
	"schemaVersion": 1,
	"id": "visualizegate",
	"version": "${version}",
	"name": "VisualizeGate",
	"description": "Visualizes Nether portals in the world with bounding-box frames so you can spot and align them at a glance.",
	"authors": [
		"kajiwara"
	],
	"contact": {
		"homepage": "https://github.com/private-kajiwara/MyFabricMod",
		"sources": "https://github.com/private-kajiwara/MyFabricMod",
		"issues": "https://github.com/private-kajiwara/MyFabricMod/issues"
	},
	"license": "CC0-1.0",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.kajiwara.visualizegate.VisualizeGateMod"
		],
		"client": [
			"com.kajiwara.visualizegate.VisualizeGateClient"
		],
		"modmenu": [
			"com.kajiwara.visualizegate.config.modmenu.GateModMenuApi"
		]
	},
	"mixins": [
		{
			"config": "visualizegate.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*"
	},
	"recommends": {
		"modmenu": "*"
	}
}
