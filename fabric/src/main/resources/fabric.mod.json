{
	"schemaVersion": 1,
	"id": "omnichest",
	"version": "${version}",
	"name": "OmniChest",
	"description": "An organization helper for players who find tidying their storage a chore.\n\nOmniChest adds a network-wide chest search with in-world pins, smart deposit, category sorting, slot locks, and reusable chest templates — one toolkit to keep your storage tidy.",
	"authors": [
		"kajiwara"
	],
	"contact": {
		"homepage": "https://github.com/private-kajiwara/MyFabricMod",
		"sources": "https://github.com/private-kajiwara/MyFabricMod",
		"issues": "https://github.com/private-kajiwara/MyFabricMod/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/omnichest/omni-chest-modmenu-icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.kajiwara.omnichest.OmniChest"
		],
		"client": [
			"com.kajiwara.omnichest.OmniChestClient"
		],
		"modmenu": [
			"com.kajiwara.omnichest.config.modmenu.OmniChestModMenu"
		]
	},
	"mixins": [
		{
			"config": "omnichest.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"recommends": {
		"modmenu": "*"
	}
}